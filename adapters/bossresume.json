    "statusField": "status",
    "approvedValue": "APPROVED",
    "requiredFields": ["schema_version", "checkpoint_type", "approved_by", "approved_at"]
  },
  "planner": {
    "phases": {
      "INTAKE": [{ "id": "product-review", "agent": "product_agent", "taskKind": "PRODUCT_INITIAL_REVIEW", "dependsOn": [] }],
      "PRD_REVIEW": [
