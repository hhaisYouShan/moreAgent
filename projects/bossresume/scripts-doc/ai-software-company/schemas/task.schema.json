{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-company.local/schemas/task.schema.json",
  "title": "Task Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "workstreamId", "projectId", "workflowId", "phase", "ownerAgent", "goal", "inputHash", "status", "attempt", "maxAttempts", "createdAt"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "taskId": {"type": "string", "minLength": 1},
    "workstreamId": {"type": "string", "minLength": 1},
    "projectId": {"type": "string", "minLength": 1},
    "workflowId": {"type": "string", "minLength": 1},
    "phase": {"type": "string", "minLength": 1},
    "ownerAgent": {"type": "string", "minLength": 1},
    "goal": {"type": "string", "minLength": 1},
    "requirementIds": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "inputHash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "dependsOn": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "softDependsOn": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "conflictsWith": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "resourceLocks": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "consumes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "produces": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "editablePaths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "forbiddenPaths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "acceptanceCommands": {"type": "array", "items": {"type": "string"}, "default": []},
    "requiredTests": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "default": []},
    "contextManifestId": {"type": ["string", "null"]},
    "sessionKey": {"type": ["string", "null"]},
    "attempt": {"type": "integer", "minimum": 1},
    "maxAttempts": {"type": "integer", "minimum": 1},
    "status": {"enum": ["PENDING", "WAITING_DEPENDENCY", "READY", "LOCKING", "LOCKED", "RUNNING", "WAITING_AGENT", "VERIFYING", "CHANGES_REQUESTED", "REPAIR_READY", "APPROVED", "FAILED", "STALE", "RECOVERING", "BLOCKED_BY_RESOURCE", "CANCELED", "SUPERSEDED"]},
    "priority": {"enum": ["LOW", "MEDIUM", "HIGH", "URGENT"]},
    "createdAt": {"type": "string", "format": "date-time"}
  }
}